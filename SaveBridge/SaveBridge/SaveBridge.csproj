<?xml version="1.0" encoding="utf-8"?>
<!--
  SaveBridge.csproj — XAML-free UWP AppContainerExe
  ==================================================
  Strategy:
    - NuGet restores Microsoft.NETCore.UniversalWindowsPlatform (NUP) 6.2.9
      which brings in the BCL facade DLLs (System.Runtime, mscorlib, etc.)
      that the XAML CSharp.targets need for type-universe resolution.
    - Import Microsoft.Windows.UI.Xaml.CSharp.targets for UAP/AppX packaging.
    - No .xaml files, no <Page> items — WMC XAML compiler has nothing to process.
    - Entry point: SaveBridge.SaveBridgeViewSource (IFrameworkViewSource) with
      headless IFrameworkView that runs the HTTP save-bridge server.
-->
<Project ToolsVersion="15.0" DefaultTargets="Build"
         xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <!-- ── Core properties ─────────────────────────────────────────────── -->
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Release</Configuration>
    <Platform      Condition=" '$(Platform)'      == '' ">ARM64</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <OutputType>AppContainerExe</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>SaveBridge</RootNamespace>
    <AssemblyName>SaveBridge</AssemblyName>
    <DefaultLanguage>en-US</DefaultLanguage>

    <!-- UAP target platform -->
    <TargetPlatformIdentifier>UAP</TargetPlatformIdentifier>
    <TargetPlatformVersion>10.0.19041.0</TargetPlatformVersion>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <MinimumVisualStudioVersion>16</MinimumVisualStudioVersion>
    <!-- UAP project type GUIDs — prevent .NET SDK from hijacking the build -->
    <ProjectTypeGuids>{A5A43C5B-DE2A-4C0C-9213-0A381AF9435A};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <!-- Suppress .NETCore,Version=v5.0.AssemblyAttributes.cs generation -->
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>

    <!-- Packaging -->
    <AppxPackageSigningEnabled>False</AppxPackageSigningEnabled>
    <GenerateAppInstallerFile>False</GenerateAppInstallerFile>
    <AppxAutoIncrementPackageRevision>False</AppxAutoIncrementPackageRevision>
    <AppxBundle>Always</AppxBundle>
    <AppxBundlePlatforms>ARM64</AppxBundlePlatforms>
    <UapAppxPackageBuildMode>SideloadOnly</UapAppxPackageBuildMode>

    <!-- AssemblyInfo.cs provides all assembly attributes -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NuGetPackageImportStamp></NuGetPackageImportStamp>
  </PropertyGroup>

  <!-- ── Release config ─────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|ARM64'">
    <OutputPath>bin\ARM64\Release\</OutputPath>
    <DefineConstants>TRACE;NETFX_CORE;WINDOWS_UWP</DefineConstants>
    <Optimize>true</Optimize>
    <DebugType>pdbonly</DebugType>
  </PropertyGroup>

  <!-- ── Debug config ───────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|ARM64'">
    <DebugSymbols>true</DebugSymbols>
    <OutputPath>bin\ARM64\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE;NETFX_CORE;WINDOWS_UWP</DefineConstants>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
  </PropertyGroup>

  <!-- ── Source files ───────────────────────────────────────────────── -->
  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="SaveBridgeView.cs" />
    <Compile Include="SaveBridgeServer.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>

  <!-- ── Package manifest ───────────────────────────────────────────── -->
  <ItemGroup>
    <AppxManifest Include="Package.appxmanifest">
      <SubType>Designer</SubType>
    </AppxManifest>
  </ItemGroup>

  <!-- ── Assets ─────────────────────────────────────────────────────── -->
  <ItemGroup>
    <Content Include="Assets\LockScreenLogo.scale-200.png" />
    <Content Include="Assets\SplashScreen.scale-200.png" />
    <Content Include="Assets\Square150x150Logo.scale-200.png" />
    <Content Include="Assets\Square44x44Logo.scale-200.png" />
    <Content Include="Assets\Square44x44Logo.targetsize-24_altform-unplated.png" />
    <Content Include="Assets\StoreLogo.png" />
    <Content Include="Assets\Wide310x150Logo.scale-200.png" />
  </ItemGroup>

  <!--
    NuGet package import — Microsoft.NETCore.UniversalWindowsPlatform
    This .props file adds System.Runtime and all other BCL facades to the
    compiler reference path (ReferencePath), which is what the XAML targets'
    WMC type-universe pass needs to resolve System.Runtime, Version=4.0.0.0.
    NuGet restores this to $(SolutionDir)\packages\ via packages.config.
  -->
  <Import Project="$(SolutionDir)\packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.9\build\Microsoft.NETCore.UniversalWindowsPlatform.props"
          Condition="Exists('$(SolutionDir)\packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.9\build\Microsoft.NETCore.UniversalWindowsPlatform.props')" />

  <!--
    Import UAP/XAML C# targets last (as is standard for UAP projects).
    Provides: UWP BCL assembly wiring, AppX packaging pipeline (MakeAppx).
    WMC XAML compiler pass runs but finds no <Page> items — it is a no-op.
    The type-universe check is satisfied by the NUP BCL facades above.
  -->
  <PropertyGroup Condition=" '$(VisualStudioVersion)' == '' or '$(VisualStudioVersion)' &lt; '15.0' ">
    <VisualStudioVersion>15.0</VisualStudioVersion>
  </PropertyGroup>

  <Import Project="$(MSBuildExtensionsPath)\Microsoft\WindowsXaml\v$(VisualStudioVersion)\Microsoft.Windows.UI.Xaml.CSharp.targets" />

  <!--
    NUP .targets is intentionally NOT imported here.
    The NUP .targets file performs a runtime validation that requires
    project.json with "win10" in runtimes, which breaks the restore.
    We only need the .props (which adds BCL facades to ReferencePath)
    and the explicit <Reference> items injected by the workflow step.
  -->

</Project>
