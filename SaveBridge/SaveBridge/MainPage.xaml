<Page
    x:Class="SaveBridge.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#1a1a2e">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="80">
            <TextBlock
                Text="🧟 SaveBridge"
                FontSize="48"
                FontWeight="Bold"
                Foreground="#e94560"
                HorizontalAlignment="Center"
                Margin="0,0,0,16"/>
            <TextBlock
                Text="Dead Island Definitive Edition — Save Transfer Bridge"
                FontSize="22"
                Foreground="#a8a8b3"
                HorizontalAlignment="Center"
                Margin="0,0,0,40"/>
            <Border
                Background="#16213e"
                BorderBrush="#e94560"
                BorderThickness="1"
                CornerRadius="8"
                Padding="40,32">
                <TextBlock
                    x:Name="StatusText"
                    Text="Initializing..."
                    FontSize="20"
                    Foreground="#eaeaea"
                    FontFamily="Consolas"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    TextWrapping="Wrap"/>
            </Border>
            <TextBlock
                Text="Keep this app running while transferring saves from your Mac."
                FontSize="16"
                Foreground="#57606a"
                HorizontalAlignment="Center"
                Margin="0,32,0,0"/>
        </StackPanel>
    </Grid>
</Page>
