<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- Restore packages to the solution-level packages\ folder
         (required by the legacy UAP .csproj HintPaths and Import paths). -->
    <add key="repositoryPath" value="packages" />
  </config>
  <packageRestore>
    <add key="enabled" value="True" />
    <add key="automatic" value="True" />
  </packageRestore>
</configuration>
